# ── Core ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-use-a-long-random-string-in-production
DB_USER=bowman
DB_PASSWORD=change-me-strong-db-password

# Your EasyPanel domain for the backend (e.g. api.bowman.yourdomain.com)
ALLOWED_HOSTS=api.yourdomain.com,localhost
CSRF_TRUSTED_ORIGINS=https://api.yourdomain.com,https://app.yourdomain.com

# Frontend → Backend connection
# Use your backend's EasyPanel public URL
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1

# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com

# ── AWS S3 (optional for file uploads) ────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=bowman-insurance-documents
AWS_S3_REGION_NAME=af-south-1

# ── M-Pesa ────────────────────────────────────────────────────────────────
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=174379
# Register this plain URL with Safaricom (no ?secret= param — secret is sent via header)
MPESA_CALLBACK_URL=https://api.yourdomain.com/api/v1/payments/mpesa/callback/
# This secret is verified via the X-Callback-Secret request header, not in the URL
MPESA_CALLBACK_SECRET=random-secret-string

# ── Paystack ──────────────────────────────────────────────────────────────
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_CALLBACK_URL=https://api.yourdomain.com/api/v1/payments/paystack/callback/

# ── Email / SMS (optional) ─────────────────────────────────────────────────
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=noreply@bowmaninsurance.co.ke
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=

# ── Sentry (optional) ─────────────────────────────────────────────────────
SENTRY_DSN=
